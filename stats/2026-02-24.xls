function fixAccessibility() {
	const qsiContainer = document.querySelector('.QSIUserDefinedHTML');
	if (!qsiContainer) return;  // Safeguard in case the element is not found
	//Add accessibility for divs
	const innerDivs = qsiContainer.querySelectorAll('div[style]');
	if (innerDivs[0]) innerDivs[0].setAttribute('role', 'presentation');
	if (innerDivs[0]) innerDivs[0].removeAttribute('tabindex');
	if (innerDivs[0]) innerDivs[0].style.zIndex = '9002';
	if (innerDivs[3]) innerDivs[3].setAttribute('role', 'presentation');
  if (innerDivs[3]) innerDivs[3].removeAttribute('tabindex');
	if (innerDivs[3]) innerDivs[3].style.zIndex = '9000';
	if (innerDivs[4]) innerDivs[4].setAttribute('aria-hidden', 'true');
	if (innerDivs[5]) innerDivs[5].setAttribute('role', 'presentation');
  if (innerDivs[5]) innerDivs[5].removeAttribute('tabindex');
	if (innerDivs[5]) innerDivs[5].style.zIndex = '9001';
	if (innerDivs[6]) innerDivs[6].setAttribute('aria-hidden', 'true');
	
	//Add accessibility for frame and powerby div
	const iframe = qsiContainer.querySelector('iframe');
	if (iframe) iframe.setAttribute('title', 'Survey');
} 
function adjustWidths() {
            // Get the width of the 'evaluate' div
            const evaluateDiv = document.getElementById('divSurveyEmbeddedElement');
            if (!evaluateDiv) return;  // Safeguard in case the element is not found
            const evalWidth = evaluateDiv.offsetWidth;

            // Get the QSI container div
            const qsiContainer = document.querySelector('.QSIUserDefinedHTML');
            if (!qsiContainer) return;  // Safeguard in case the element is not found
            qsiContainer.style.width = evalWidth + 'px';

            // Adjust the width of the inner divs to specified percentages
            const innerDivs = qsiContainer.querySelectorAll('div[style]');

            // Safeguard to ensure we aren't exceeding the length of innerDivs array
            if (innerDivs[0]) innerDivs[0].style.width = '100%';
            if (innerDivs[1]) innerDivs[1].style.width = '100%';
            if (innerDivs[2]) innerDivs[2].style.width = '100%';
            if (innerDivs[3]) innerDivs[3].style.width = '100%';

            const scrollable = qsiContainer.querySelector(".scrollable");
            if (scrollable) scrollable.style.width = '100%';

            // Adjust the iframe width to 100%
            const iframe = qsiContainer.querySelector('iframe');
            if (iframe) iframe.style.width = '100%';
        }

        const handleWalkerResize = (event) => {
            if (event.data) {
              //  console.log("EVENTDATA:", event.data);
                let newHeight;

                // Check if event.data is a string "closeQSIWindow"
                if (event.data === "closeQSIWindow") {
                    newHeight = 175;
                } else {
                    try {
                        const message = JSON.parse(event.data);

                        // Check for event type "walkerResize" and get the newHeight value
                        if (message.event === "walkerResize") {
                            newHeight = message.value;
                        }
                    } catch (error) {
                       // console.error("Invalid message data", error);
                    }
                }

                // If newHeight has been set, adjust the heights of the elements
                if (newHeight !== undefined) {
                 //   console.log("newHeight", newHeight);
                    const qsiContainer = document.querySelector('.QSIUserDefinedHTML');
                    if (qsiContainer) {
                        // Adjust elements' height based on the newHeight
                        const innerDivs = qsiContainer.querySelectorAll('div[style]');
                        if (innerDivs[0]) innerDivs[0].style.height = `${newHeight}px`;
                        if (innerDivs[1]) innerDivs[1].style.height = `${newHeight}px`;
                        if (innerDivs[2]) innerDivs[2].style.height = `${newHeight}px`;
                        if (innerDivs[3]) innerDivs[3].style.height = `${newHeight}px`;
                        qsiContainer.style.height = `${newHeight}px`

                        const scrollable = qsiContainer.querySelector('.scrollable');
                        if (scrollable) scrollable.style.height = `${newHeight}px`;

                        const iframe = qsiContainer.querySelector('iframe');
                        if (iframe) iframe.style.height = `${newHeight}px`;
                    }
                }
            }
        };        // Event listener for window resize
        window.addEventListener('resize', adjustWidths);
        window.addEventListener("message", handleWalkerResize, false);

        setTimeout(() => {
		    fixAccessibility();
            adjustWidths();
            //handleWalkerResize({ data: JSON.stringify({ value: 150 }) })
        }, 2500)
		setTimeout(() => {
		    fixAccessibility();
        }, 3000)
        // Initial call to set the widths
        adjustWidths();
</script><div class="globalfooter aem-GridColumn aem-GridColumn--default--12" id="divSurveyEmbeddedElement"><!--DO NOT REMOVE-CONTENTS PLACED HERE--></div>

<!--END WEBSITE FEEDBACK SNIPPET-->
   

    

