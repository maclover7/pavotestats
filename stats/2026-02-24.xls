    <script type="module" src="https://static.cloud.coveo.com/atomic/v2/atomic.esm.js"></script>
<link rel="stylesheet" href="https://static.cloud.coveo.com/atomic/v2/themes/coveo.css"/>
<script src="https://cdn.jsdelivr.net/npm/add-to-calendar-button@2" async defer></script>
<script src="https://cdn.jsdelivr.net/npm/dompurify@3.0.5/dist/purify.min.js"></script>

    <script type="module">
        import {
            loadFacetSetActions
        } from 'https://static.cloud.coveo.com/headless/v2/headless.esm.js';

        const coveoSearch = new (function () {
            // Keeps focus within the refine dialog.
            this.focusTrap = (e) => {
                const firstFocusableElement = document.querySelector('.cmp-coveo-search-sort-refine-modal__header__close');
                const lastFocusableElement = document.querySelector('.cmp-coveo-search-sort-refine-modal__footer__apply');
                const isTabPressed = e.key === 'Tab' || e.keyCode === 9;

                if (!isTabPressed) {
                    return;
                }

                if (e.shiftKey) {
                    if (document.activeElement === firstFocusableElement) {
                        lastFocusableElement.focus();
                        e.preventDefault();
                    }
                } else { // if tab key is pressed
                    if (document.activeElement === lastFocusableElement) {
                        firstFocusableElement.focus();
                        e.preventDefault();
                    }
                }
            };

            // Key press handler to close modal if ESC is pressed.
            this.handleEscPress = (e) => {
                const isEscPressed = e.key === 'Escape' || e.keyCode === 27;

                if (!isEscPressed) {
                    return;
                }

                coveoSearch.closeRefineModal();
                e.preventDefault();
            }

            // Opens the refine dialog.
            this.openRefineModal = () => {
                const modalBg = document.querySelector('.cmp-coveo-search-sort-refine-modal__overlay-bg');
                const modal = document.querySelector('.cmp-coveo-search-sort-refine-modal')
                const applyBtn = document.querySelector('.cmp-coveo-search-sort-refine-modal__footer__apply');

                // Allows interaction for tab screen readers within dialog.
                modal.setAttribute('aria-hidden', false);
                modal.setAttribute('tabindex', '0');

                // Shows the dialog and locks scroll outside of it.
                modalBg.classList.add('cmp-coveo-search-sort-refine-modal__overlay-bg--shown');
                modal.classList.add('cmp-coveo-search-sort-refine-modal--shown');
                document.body.classList.add('modal-open');
                const closeBtn = document.querySelector('.cmp-coveo-search-sort-refine-modal__header__close');
                // Wire up all the ways to close the dialog.
                closeBtn.addEventListener('click', coveoSearch.closeRefineModal);
                applyBtn.addEventListener('click', coveoSearch.closeRefineModal);
                modalBg.addEventListener('click', coveoSearch.closeRefineModal);

                // Wires up keyboard handlers.
                modal.addEventListener('keydown', coveoSearch.focusTrap);
                modal.addEventListener('keyup', coveoSearch.handleEscPress);

                // Sets focus on the first focusable element (cluse button) in the dialog.
                setTimeout(() => {
                    closeBtn.focus();
                }, 500);

            }

            this.closeRefineModal = () => {
                const modalBg = document.querySelector('.cmp-coveo-search-sort-refine-modal__overlay-bg');
                const modal = document.querySelector('.cmp-coveo-search-sort-refine-modal');
                const modalTrigger = document.getElementById('cmp-coveo-search-modal-trigger');
                const modalContent = document.querySelector('.cmp-coveo-search-sort-refine-modal__content');

                // Removes dialog from tab order, hides from screen readers and resets scroll position of content.
                modal.setAttribute('aria-hidden', true);
                modal.setAttribute('tabindex', '-1');
                modalContent.scrollTop = 0;

                // Hides the dialog and allows scrolling of body again.
                modalBg.classList.remove('cmp-coveo-search-sort-refine-modal__overlay-bg--shown');
                modal.classList.remove('cmp-coveo-search-sort-refine-modal--shown');
                document.body.classList.remove('modal-open');

                // Remove keyboard event listeners.
                modal.removeEventListener('keydown', coveoSearch.focusTrap);
                modal.removeEventListener('keyup', coveoSearch.handleEscPress);

                // Directs focus back to the dialog opener.
                modalTrigger.focus();
            }

            this.addtoCalDateFormat = (dateToFormat) => {
            const date = new Date(dateToFormat);
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');

            return [year, month, day].join('-');
        }

        this.addtoCalTimeFormat = (dateToFormat) => {
            const date = new Date(dateToFormat);

            return date.toLocaleTimeString('en-GB', {hour: '2-digit', minute:'2-digit'});
        }

        this.formatAddress = (data) => {
            let formattedAddress = '';
            
            if (data.copapwpaddressline1) {
                formattedAddress += data.copapwpaddressline1;
            }

            if (data.copapwpaddressline2) {
                if (formattedAddress.length > 0) {
                    formattedAddress += ' ' + data.copapwpaddressline2;
                } else {
                    formattedAddress += data.copapwpaddressline2;
                }
            }

            if (data.copapwpaddressline3) {
                if (formattedAddress.length > 0) {
                    formattedAddress += ' ' + data.copapwpaddressline3;
                } else {
                    formattedAddress += data.copapwpaddressline2;
                }
            }

            if (data.copapwpwcitystatezip) {
                if (formattedAddress.length > 0) {
                    formattedAddress += ' ' + data.copapwpwcitystatezip;
                } else {
                    formattedAddress += data.copapwpwcitystatezip;
                }
            }

            return formattedAddress;
        }

        this.addtoCalendarLink = (data) => {
            const formattedStartDate = this.addtoCalDateFormat(data.copapwpstartdate);
            const formattedStartTime = this.addtoCalTimeFormat(data.copapwpstartdate);
            const formattedEndDate = data.copapwpenddate ?
                this.addtoCalDateFormat(data.copapwpenddate) :
                this.addtoCalDateFormat(data.copapwpstartdate + (3600000 * 2));
            const formattedEndTime = data.copapwpenddate ?
                this.addtoCalTimeFormat(data.copapwpenddate) :
                this.addtoCalTimeFormat(data.copapwpstartdate + (3600000 * 2));
            const formattedAddress = this.formatAddress(data);
            const eventDescription = data.copapwpshortdescription ? data.copapwpshortdescription : '';
            
            return (`
                <style>
                    .atcb-initialized.atcb-buttons-list {
                        justify-content: flex-start !important;
                    }
                    add-to-calendar-button::part(atcb-button-wrapper) {
                        display: inline-block;
                        margin: .75rem .75rem 0 0;
                    }
                    add-to-calendar-button::part(atcb-button) {
                        padding: 0.625rem 1.5rem;
                        margin: 0;
                        box-shadow: none;
                        font-size: .875rem;
                        line-height: 1.25;
                        margin: 0;
                        background-color: transparent;
                        border-color: #757680;
                        color: #00629E;
                        border-radius: 0;
                    }
                    add-to-calendar-button::part(atcb-button):hover {
                        color: #00629E;
                        background-color: rgba(0, 98, 158, 0.08);
                    }
                    add-to-calendar-button::part(atcb-button):focus,
                    add-to-calendar-button::part(atcb-button):focus-visible {
                        outline: 1px solid #0f62fe;
                        color: #00629E;
                        background-color: rgba(0, 98, 158, 0.08);
                    }
                    add-to-calendar-button::part(atcb-list-text) {
                        font-family: 'PlusJakartaSans';
                        font-weight: 600;
                    }
                    add-to-calendar-button::part(atcb-list-icon) {
                        width: 1rem;
                        height: 1rem;
                        line-height: 1rem;
                        margin-right: .5rem;
                        color: #000000;
                    }
                </style>
                <add-to-calendar-button
                    name="${data.copapwptitle}"
                    description="${eventDescription}"
                    options="'apple','google','ms365','ical'" 
                    buttonslist="true"
                    inline="true" 
                    startDate="${formattedStartDate}"
                    endDate="${formattedEndDate}"
                    startTime="${formattedStartTime}"
                    endTime="${formattedEndTime}"
                    location="${formattedAddress}"
                    timeZone="America/New_York">
                </add-to-calendar-button>
            `);
        }

            this.init = () => {
                (async () => {
                    await customElements.whenDefined('atomic-search-interface');

                    const searchInterface = document.querySelector('#search');
                    const teaserSearchInterface = document.querySelector('#teaser-search');
                    const headerSearchInterface = document.querySelector('#header-search');
                    let customizeFacets = true;
                    // Initialize main search interface
                    if (searchInterface) {
                        await searchInterface.initialize({
                            accessToken: 'xx4e57cda9-3464-437d-9375-b947ca6b72c8',
                            organizationId: 'commonwealthofpennsylvaniaproductiono8jd9ckm',
                            organizationEndpoints: await searchInterface.getOrganizationEndpoints('commonwealthofpennsylvaniaproductiono8jd9ckm'),
                            analytics: {
                                analyticsClientMiddleware: (eventType, payload) => {
                                    const queryTextelm = document.getElementById('search-no-results-query-text');
                                    if (eventType === 'search') {
                                        if (queryTextelm) {
                                          const cleanHTML = DOMPurify.sanitize(payload?.queryText ?? '', {
                                            ALLOWED_TAGS: [],
                                            ALLOWED_ATTR: []
                                          });
                                          queryTextelm.innerHTML = cleanHTML;
                                        }
                                    }
                                    return payload;
                                }
                            },
                            search: {
                                preprocessSearchResponseMiddleware: (response) => {
                                    response.body.results.forEach((result) => {
                                        if (result.raw.copapwpadditionalinformation) {
                                            let template = '<style>li,p,span,ul{font-size:.75rem;line-height:1.5;font-weight:400;color:#001849}p{margin:.5rem 0}ul{margin:.5rem 0;padding-left:1rem}a{color:#00629e}a:hover{color:#001849;text-decoration:underline}a:focus,a:focus-visible{outline:1px solid #0f62fe;outline-offset:0}</style>';
                                            template += result.raw.copapwpadditionalinformation.toString();
                                            result.raw.copapwpadditionalinformationformatted = template;
                                        }

                                        if (result.raw.copapwpherodescription) {
                                            let template = '<style>li,p,span,ul{font-size:.75rem;line-height:1.5;font-weight:400;color:#001849}p{margin:0 0 .5rem}p:last-of-type{margin-bottom: 0;}ul{margin:.5rem 0;padding-left:1rem}a{color:#00629e}a:hover{color:#001849;text-decoration:underline}a:focus,a:focus-visible{outline:1px solid #0f62fe;outline-offset:0}</style>';
                                            template += result.raw.copapwpherodescription.toString();
                                            result.raw.copapwpherodescriptionformatted = template;
                                        }

                                        if (result.raw.copapwpcontenttype) {
                                            if ((result.raw.copapwpcontenttype.includes('Actions')) ||
                                                (result.raw.copapwpcontenttype.includes('Location') &&
                                                    (result.raw.copapwpcontactname2 ||
                                                        result.raw.copapwpcontactlabel2 ||
                                                        result.raw.copapwpphonenumber2 ||
                                                        (result.raw.copapwplinkurl2 && result.raw.copapwplinklabel2) ||
                                                        (result.raw.copapwpexternallinkurl2 && result.raw.copapwplinklabel2) ||
                                                        result.raw.copapwpadditionalinformation) ||
                                                    (result.raw.copapwpdocumentdownload2 && result.raw.copapwpdocumentdownload2linklabel) ||
                                                    (result.raw.copapwpcontenttype.includes('Event') &&
                                                        (result.raw.copapwpcontactname1 ||
                                                            result.raw.copapwpcontactlabel1 ||
                                                            result.raw.copapwpphonenumber1 ||
                                                            result.raw.copapwpadditionalinformation ||
                                                            result.raw.copapwpaddressline1 ||
                                                            result.raw.copapwpemail ||
                                                            result.raw.copapwpeventfee ||
                                                            result.raw.copapwpcity ||
                                                            result.raw.copapwpstate ||
                                                            result.raw.copapwpzip)
                                                    ))
                                            ) {
                                                result.raw.copapwpshowadditionalinformation = 'true';
                                            }

                                            if ((result.raw.copapwpcontenttype.includes('Location') &&
                                                (result.raw.copapwpaddressline1 ||
                                                    result.raw.copapwpaddressline2 ||
                                                    result.raw.copapwpaddressline3 ||
                                                    result.raw.copapwpcity ||
                                                    result.raw.copapwpstate ||
                                                    result.raw.copapwpfacility ||
                                                    result.raw.copapwpzipcode) ||
                                                (result.raw.copapwpcontenttype.includes('Event') &&
                                                    (result.raw.copapwpaddressline1 ||
                                                        result.raw.copapwpaddressline2 ||
                                                        result.raw.copapwpaddressline3 ||
                                                        result.raw.copapwpcity ||
                                                        result.raw.copapwpstate ||
                                                        result.raw.copapwpzipcode ||
                                                        result.raw.copapwpfacility)
                                                ))
                                            ) {
                                                result.raw.copapwpshowaddress = 'true';
                                            }

                                            if ((result.raw.copapwpcontenttype.includes('Location') ||
                                                result.raw.copapwpcontenttype.includes('Event')) &&
                                                (result.raw.copapwpcity ||
                                                    result.raw.copapwpstate ||
                                                    result.raw.copapwpzipcode)
                                            ) {
                                                let formattedCityStateZip = '';

                                            if (result.raw.copapwpcity) {
                                                formattedCityStateZip += result.raw.copapwpcity.trim();
                                            }

                                            if (result.raw.copapwpstate) {
                                                if (Array.isArray(result.raw.copapwpstate)) {
                                                     if (formattedCityStateZip.length > 0) {
                                                        formattedCityStateZip += ', ' + result.raw.copapwpstate[0].trim();
                                                    } else {
                                                        formattedCityStateZip += result.raw.copapwpstate[0].trim();
                                                    }
                                                } else {
                                                    if (formattedCityStateZip.length > 0) {
                                                        formattedCityStateZip += ', ' + result.raw.copapwpstate.trim();
                                                    } else {
                                                        formattedCityStateZip += result.raw.copapwpstate.trim();
                                                    }
                                                }
                                            }

                                            if (result.raw.copapwpzipcode) {
                                                if (formattedCityStateZip.length > 0) {
                                                    formattedCityStateZip += ', ' + result.raw.copapwpzipcode.trim();
                                                } else {
                                                    formattedCityStateZip += result.raw.copapwpzipcode.trim();
                                                }
                                            }

                                                result.raw.copapwpwcitystatezip = formattedCityStateZip;
                                            }

                                            if (result.raw.copapwpcontenttype.includes('Event') && result.raw.copapwpstartdate && result.raw.copapwptitle) {
                                                result.raw.copapwpshowadditionalinformation = 'true';
                                                result.raw.copapwpaddtocalendar = this.addtoCalendarLink(result.raw);
                                            }
                                        }

                                        return result;
                                    });

                                    const downloadBtn = document.querySelector('.cmp-coveo-search__result-downloadcsv');

                                    if (response?.body?.totalCount == 0) {
                                        if (downloadBtn) {
                                            downloadBtn.style.display = 'none';
                                        }
                                    } else {
                                        if (downloadBtn) {
                                            downloadBtn.style.display = 'block';
                                        }
                                    }

                                    return response;
                                },
                                preprocessFacetSearchResponseMiddleware: (response) => response,
                                preprocessQuerySuggestResponseMiddleware: (response) => response,
                            },
                        });

                        const engine = searchInterface.engine;
                        const action = loadFacetSetActions(engine).toggleSelectFacetValue({
                            facetId: "copapwpeventstatus",
                            selection: {
                                value: 'Current',
                                state: "selected",
                            }
                        });

                        const action2 = loadFacetSetActions(engine).toggleSelectFacetValue({
                            facetId: "copapwpeventstatus",
                            selection: {
                                value: 'Future',
                                state: "selected",
                            }
                        });
                        engine.dispatch(action);
                        engine.dispatch(action2);

                        searchInterface.executeFirstSearch();

                        const skipBtn = document.querySelector('a[href="#content"]');

                        if (skipBtn) {
                            skipBtn.addEventListener('click', function (e) {
                                e.preventDefault();

                                const contentDiv = document.getElementById('content');

                                if (contentDiv) {
                                    contentDiv.focus();
                                }
                            });
                        }
                    }

                    // Initialize hero search bar
                    if (headerSearchInterface) {
                        await headerSearchInterface.initialize({
                            accessToken: 'xx4e57cda9-3464-437d-9375-b947ca6b72c8',
                            organizationId: 'commonwealthofpennsylvaniaproductiono8jd9ckm',
                            organizationEndpoints: await headerSearchInterface.getOrganizationEndpoints('commonwealthofpennsylvaniaproductiono8jd9ckm'),
                            analytics: {
                                analyticsClientMiddleware: (eventType, payload) => {
                                    if (eventType === 'search') {
                                        window?.adobeDatalayer?.push(
                                            {
                                                event: eventType,
                                                eventInfo: {
                                                    action: 'Search Click',
                                                    category: eventType,
                                                    id: eventType,
                                                    label: payload.queryText,
                                                    name: eventType,
                                                    parentId: 'header',
                                                    targetURL: '/en/search.html.html',
                                                    type: 'other',
                                                }
                                            }
                                        );
                                    }
                                    return payload;
                                }
                            }
                        });
                    }

                    // Initialize hero search bar
                    if (teaserSearchInterface) {
                        await teaserSearchInterface.initialize({
                            accessToken: 'xx4e57cda9-3464-437d-9375-b947ca6b72c8',
                            organizationId: 'commonwealthofpennsylvaniaproductiono8jd9ckm',
                            organizationEndpoints: await teaserSearchInterface.getOrganizationEndpoints('commonwealthofpennsylvaniaproductiono8jd9ckm'),
                        });
                    }
                })();
                let isEditMode = false;
                const cookies = document.cookie.split(';');
                cookies.forEach((cookie) => {
                    let [key, value] = cookie.trim().split('=');
                    if (key.includes('wcmmode') && value.includes('edit')) {
                        isEditMode = true;
                    }
                })
                if (document.getElementsByClassName('cmp-coveo-search-modal-open-default')?.length > 0 && !isEditMode
                ) {
                    if (window.innerWidth <= 991) {
                        setTimeout(() => {
                            document.querySelector('atomic-refine-modal')?.setAttribute('is-open', true);
                        }, 1000);

                    }
                    else {
                        coveoSearch.openRefineModal();
                    }
                }

                if (document.getElementById('cmp-coveo-search-modal-trigger')) {
                    document
                        .getElementById('cmp-coveo-search-modal-trigger')
                        .addEventListener('click', coveoSearch.openRefineModal);
                }
            };
        })();

        document.addEventListener('DOMContentLoaded', coveoSearch.init(), false);
    </script>

    <!-- Include the custom script authored in page properties -->

</head>
